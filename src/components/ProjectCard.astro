---
import GithubIcon from './icons/GithubIcon.astro';

type BadgeColor = 'indigo' | 'cyan' | 'green';

interface Badge {
  text: string;
  color: BadgeColor;
}

interface Props {
  href: string;
  title: string;
  description: string;
  badges: Badge[];
}

const { href, title, description, badges } = Astro.props;

const colorClasses: Record<BadgeColor, string> = {
  indigo:
    'bg-terminal-accent-indigo/10 text-terminal-accent-indigo border-terminal-accent-indigo/20',
  cyan: 'bg-terminal-accent-cyan/10 text-terminal-accent-cyan border-terminal-accent-cyan/20',
  green: 'bg-terminal-accent-green/10 text-terminal-accent-green border-terminal-accent-green/20',
};
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class="block p-3 rounded-md bg-terminal-surface border border-terminal-border hover:border-terminal-accent-indigo/30 transition-all duration-200 group focus:outline-none focus-visible:ring-2 focus-visible:ring-terminal-accent-indigo focus-visible:ring-offset-2 focus-visible:ring-offset-terminal-bg"
>
  <div class="flex items-center gap-2 mb-1.5">
    <GithubIcon
      class="w-3.5 h-3.5 text-terminal-text-muted group-hover:text-terminal-accent-indigo transition-colors"
    />
    <h3 class="text-xs font-semibold text-terminal-text-bright">{title}</h3>
  </div>
  <p class="text-[10px] text-terminal-text-muted mb-2">{description}</p>
  <div class="flex flex-wrap gap-1">
    {
      badges.map((badge) => (
        <span class={`px-2 py-0.5 text-[10px] rounded-full border ${colorClasses[badge.color]}`}>
          {badge.text}
        </span>
      ))
    }
  </div>
</a>
