---
import Layout from '../layouts/Layout.astro';
import MobileBar from '../components/MobileBar.astro';
import Header from '../components/Header.astro';
import TabNav from '../components/TabNav.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ExperienceEntry from '../components/ExperienceEntry.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';

const tabs = [
  { id: 'about', label: 'about' },
  { id: 'projects', label: 'projects' },
  { id: 'experience', label: 'experience' },
  { id: 'community', label: 'community' },
  { id: 'contact', label: 'contact' },
];

const publicProjects = [
  {
    href: 'https://github.com/muratlevent/keyboard',
    title: 'Keyboard Simulator',
    description: 'Interactive 3D mechanical keyboard demo',
    badges: [
      { text: 'JavaScript', color: 'indigo' as const },
      { text: 'Three.js', color: 'cyan' as const },
    ],
  },
  {
    href: 'https://github.com/muratlevent/ShopifyCategoryFetcher',
    title: 'Shopify Category Fetcher',
    description: 'API scraping tool',
    badges: [{ text: 'Java', color: 'cyan' as const }],
  },
  {
    href: 'https://github.com/muratlevent/tweetrends',
    title: 'X (Twitter) Trend Scraper',
    description: 'Trend keyword analysis scraper',
    badges: [
      { text: 'Python', color: 'indigo' as const },
      { text: 'Playwright', color: 'cyan' as const },
    ],
  },
  {
    href: 'https://github.com/muratlevent/gootrend',
    title: 'Gootrend',
    description: 'Google Trends keyword extraction tool',
    badges: [
      { text: 'Python', color: 'indigo' as const },
      { text: 'pytrends', color: 'cyan' as const },
    ],
  },
  {
    href: 'https://github.com/muratlevent/shopify-app-store-scraper',
    title: 'Shopify App Store Scraper',
    description: 'Maintained fork with reliability and data extraction fixes',
    badges: [
      { text: 'Python', color: 'indigo' as const },
      { text: 'Scrapy', color: 'cyan' as const },
      { text: 'Fork', color: 'green' as const },
    ],
  },
  {
    href: 'https://github.com/muratlevent/QuizApp',
    title: 'Quiz App',
    description: 'Kahoot-inspired backend',
    badges: [
      { text: 'Spring Boot', color: 'cyan' as const },
      { text: 'Java', color: 'cyan' as const },
    ],
  },
];

const contactItems = [
  { key: 'email', value: 'contact@muratlevent.com' },
  { key: 'github', value: 'github.com/muratlevent', href: 'https://github.com/muratlevent' },
  { key: 'status', value: 'Open to new opportunities' },
  { key: 'location', value: 'Turkey' },
];
---

<Layout>
  <MobileBar />

  <!-- Main container -->
  <div class="max-w-3xl mx-auto px-6 pt-16 md:pt-12 pb-6 flex flex-col h-full">
    <Header />
    <TabNav tabs={tabs} />

    <!-- ════════════════ CONTENT PANES ════════════════ -->
    <main class="flex-1 min-h-0 overflow-y-auto scrollbar-hide" id="content-area">
      <!-- ─── TAB: ABOUT ─── -->
      <section id="tab-about" class="tab-pane" role="tabpanel" aria-labelledby="tab-btn-about">
        <!-- Shell prompt with typewriter -->
        <div class="mb-6 text-sm">
          <span class="text-terminal-accent-indigo">muratlevent@server</span>
          <span class="text-terminal-accent-cyan ml-1">~&gt;</span>
          <span class="ml-2">
            <span id="typewriter-target" class="text-terminal-text-muted"></span>
            <span id="typewriter-cursor" class="typewriter-cursor"></span>
          </span>
        </div>

        <!-- Bio content (hidden until typewriter completes) -->
        <div id="about-content" class="about-reveal space-y-5 text-sm leading-relaxed">
          <p class="text-terminal-text-bright">
            I'm Murat — a software engineer based in Turkey who builds robust web applications, data
            extraction systems, and AI-driven mobile tools. I value clean code, the open-source
            ethos, and turning complex problems into intuitive solutions.
          </p>

          <!-- Status line -->
          <div
            class="flex items-start gap-2 px-4 py-3 rounded-md bg-terminal-surface border border-terminal-border"
          >
            <span class="text-terminal-accent-green mt-0.5 shrink-0">▸</span>
            <p class="text-terminal-text-muted text-xs">
              <span class="text-terminal-text">Currently exploring</span> AI-integrated DevTools and advanced
              scraping architectures.
            </p>
          </div>

          <!-- Decorative terminal info -->
          <div
            class="text-xs text-terminal-text-muted space-y-1 pt-4 border-t border-terminal-border"
          >
            <p>
              <span class="text-terminal-accent-indigo">λ</span> Preferred stack: Python · TypeScript
              · React Native · AWS
            </p>
            <p>
              <span class="text-terminal-accent-indigo">λ</span> Editor: Neovim / VS Code · Terminal:
              Ghostty · Shell: Fish
            </p>
          </div>
        </div>
      </section>

      <!-- ─── TAB: PROJECTS ─── -->
      <section
        id="tab-projects"
        class="tab-pane hidden"
        role="tabpanel"
        aria-labelledby="tab-btn-projects"
      >
        <!-- Currently Focus -->
        <div class="mb-8">
          <h2
            class="text-xs font-bold text-terminal-text-muted uppercase tracking-widest mb-4 flex items-center gap-2"
          >
            <span>🎯</span> Currently Focus
          </h2>
          <div class="space-y-4">
            <!-- PipeRead Mobile -->
            <div
              class="group p-4 rounded-md bg-terminal-surface border border-terminal-border hover:border-terminal-text-muted/30 transition-colors duration-200"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-sm font-semibold text-terminal-text-bright">pipeRead Mobile</h3>
                <span
                  class="text-[10px] text-orange-400 bg-orange-400/10 px-2 py-0.5 rounded-full border border-orange-400/20"
                  >in development</span
                >
              </div>
              <p class="text-xs text-terminal-text-muted mb-3 leading-relaxed">
                Native mobile companion app for pipeRead. Enhancing experience with offline support
                and push notifications.
              </p>
              <div class="flex flex-wrap gap-1.5">
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-indigo/10 text-terminal-accent-indigo border border-terminal-accent-indigo/20"
                  >React Native</span
                >
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-indigo/10 text-terminal-accent-indigo border border-terminal-accent-indigo/20"
                  >Expo</span
                >
              </div>
            </div>
            <!-- PipeRead -->
            <div
              class="group p-4 rounded-md bg-terminal-surface border border-terminal-border hover:border-terminal-text-muted/30 transition-colors duration-200"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-sm font-semibold text-terminal-text-bright">pipeRead</h3>
                <span
                  class="text-[10px] text-terminal-accent-green px-2 py-0.5 rounded-full border border-terminal-accent-green/20"
                  >live</span
                >
              </div>
              <p class="text-xs text-terminal-text-muted mb-3 leading-relaxed">
                Personal AI librarian mobile app. Personalized recommendation flows and metadata
                extraction.
              </p>
              <div class="flex flex-wrap gap-1.5">
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-indigo/10 text-terminal-accent-indigo border border-terminal-accent-indigo/20"
                  >React Native</span
                >
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-indigo/10 text-terminal-accent-indigo border border-terminal-accent-indigo/20"
                  >Expo</span
                >
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-cyan/10 text-terminal-accent-cyan border border-terminal-accent-cyan/20"
                  >Supabase</span
                >
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-green/10 text-terminal-accent-green border border-terminal-accent-green/20"
                  >AI</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Public Open Source -->
        <div>
          <h2
            class="text-xs font-bold text-terminal-text-muted uppercase tracking-widest mb-4 flex items-center gap-2"
          >
            <span>🌐</span> Public / Open Source
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {publicProjects.map((project) => <ProjectCard {...project} />)}
          </div>
        </div>
      </section>

      <!-- ─── TAB: EXPERIENCE ─── -->
      <section
        id="tab-experience"
        class="tab-pane hidden"
        role="tabpanel"
        aria-labelledby="tab-btn-experience"
      >
        <div class="relative pl-6 border-l border-terminal-border space-y-8">
          <ExperienceEntry
            title="Independent Software Engineer"
            period="Jan 2026 — Present"
            description="Developing proprietary AI applications (PipeRead) and robust Python-based data scraping scripts. Building end-to-end mobile experiences with React Native and integrating AI pipelines."
            badges={[{ text: 'current', color: 'green' }]}
            isCurrent={true}
          />
          <ExperienceEntry
            title="Software Engineer"
            subtitle="Prisync"
            period="Jan 2022 — Dec 2025"
            description="Shell Team Member. Focused on Python, large-scale Web Scraping pipelines, AWS architecture, and Full-stack development. 4 years of optimizing data flows."
            badges={[
              { text: 'Python', color: 'indigo' },
              { text: 'AWS', color: 'cyan' },
              { text: 'Web Scraping', color: 'indigo' },
              { text: 'Full-stack', color: 'cyan' },
            ]}
          />
        </div>
      </section>

      <!-- ─── TAB: COMMUNITY ─── -->
      <section
        id="tab-community"
        class="tab-pane hidden"
        role="tabpanel"
        aria-labelledby="tab-btn-community"
      >
        <div class="space-y-8">
          <!-- FOSDEM -->
          <div>
            <h2
              class="text-xs font-bold text-terminal-text-muted uppercase tracking-widest mb-4 flex items-center gap-2"
            >
              <span class="text-terminal-accent-indigo">▸</span> FOSDEM
            </h2>
            <div class="p-4 rounded-md bg-terminal-surface border border-terminal-border">
              <p class="text-xs text-terminal-text leading-relaxed">
                Attended <span class="text-terminal-text-bright font-semibold">FOSDEM</span> in Brussels
                for two consecutive years (<span class="text-terminal-accent-cyan">2025</span> &
                <span class="text-terminal-accent-cyan">2026</span>), deeply engaging with the
                European open-source developer ecosystem.
              </p>
              <div class="flex gap-2 mt-3">
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-indigo/10 text-terminal-accent-indigo border border-terminal-accent-indigo/20"
                  >Brussels</span
                >
                <span
                  class="px-2 py-0.5 text-[10px] rounded-full bg-terminal-accent-cyan/10 text-terminal-accent-cyan border border-terminal-accent-cyan/20"
                  >Open Source</span
                >
              </div>
            </div>
          </div>

          <!-- Open Source Contributions -->
          <div>
            <h2
              class="text-xs font-bold text-terminal-text-muted uppercase tracking-widest mb-4 flex items-center gap-2"
            >
              <span class="text-terminal-accent-indigo">▸</span> Open Source Contributions
            </h2>
            <div class="p-4 rounded-md bg-terminal-surface border border-terminal-border">
              <p class="text-xs text-terminal-text leading-relaxed">
                Active participant in the open-source ethos. Focused on making the ecosystem better
                through
                <span class="text-terminal-text-bright">documentation improvements</span>,
                <span class="text-terminal-text-bright">typo fixes</span> in public repositories, and
                <span class="text-terminal-text-bright">collaborative problem-solving</span>.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── TAB: CONTACT ─── -->
      <ContactSection items={contactItems} />
    </main>

    <Footer />
  </div>

  <!-- ════════════════ INITIALIZATION SCRIPT ════════════════ -->
  <script>
    import { init } from '../scripts/main';
    document.addEventListener('DOMContentLoaded', init);
  </script>
</Layout>
